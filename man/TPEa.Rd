\if{html}{\out{<div class="r">}}\preformatted{TPEa$runEstimation(
  varID = 1,
  envID = 1,
  maxiter = 2000,
  paramnames = NA,
  metric = "RMSE",
  score_fn = get_score,
  weigh_fn = NA,
  bounds = NA
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
